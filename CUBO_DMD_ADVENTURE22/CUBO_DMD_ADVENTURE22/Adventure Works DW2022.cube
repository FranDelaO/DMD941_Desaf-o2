  <Source dwd:design-time-name="bdd35c37-ac8d-4498-83f6-ca0b273aaed3">
    <DataSourceViewID>Adventure Works DW2022</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="9437b72a-a0b1-4094-9aea-bb47d139595f">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
El comando CALCULATE controla la agregación de celdas hoja en el cubo.
Si se elimina o modifica el comando CALCULATE, se ven afectados los datos del cubo.
Solo debe editar este comando si especifica manualmente cómo se agrega el cubo.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[VentasAnioAnterior]
 AS (ParallelPeriod(
       [Order Date].[Calendar Year].[Calendar Year],
       1,
       [Order Date].[Calendar Year].CurrentMember),
   [Measures].[Sales Amount]), 
FORMAT_STRING = "Currency", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Internet Sales'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[CrecimientoVsAnioAnterior]
 AS IIF(
       [Measures].[VentasAnioAnterior] = 0,
       NULL,
       ([Measures].[Sales Amount] - [Measures].[VentasAnioAnterior]) 
       / [Measures].[VentasAnioAnterior]
   ), 
FORMAT_STRING = "Percent", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Internet Sales'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[PorcentajeDelTotalVentas]
 AS [Measures].[Sales Amount] / 
  ([Measures].[Sales Amount], [Dim Product].[Product Category Name].[All]), 
FORMAT_STRING = "Percent", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Internet Sales'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[VentasAcumuladasCategoria]
 AS SUM(
    HEAD(
      ORDER(
        [Dim Product].[Product Category Name].[Product Category Name].MEMBERS,
        [Measures].[Sales Amount],BDESC
      ),
      RANK(
        [Dim Product].[Product Category Name].CURRENTMEMBER, ORDER(
        [Dim Product].[Product Category Name].[Product Category Name].MEMBERS,
        [Measures].[Sales Amount],BDESC
        )
      )
    ),
    [Measures].[Sales Amount]
  ), 
FORMAT_STRING = "Currency", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Internet Sales'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[PorcentajeAcumuladoCategoria]
 AS [Measures].[VentasAcumuladasCategoria] / 
  ([Measures].[Sales Amount], [Dim Product].[Product Category Name].[All]), 
FORMAT_STRING = "Percent", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Internet Sales'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[PromedioVentasPorPais]
 AS AVG(
    [Dim Sales Territory].[Sales Territory Country].[Sales Territory Country].MEMBERS,
    [Measures].[Sales Amount]
  ), 
FORMAT_STRING = "Currency", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Internet Sales'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[DiferenciaVsPromedio]
 AS [Measures].[Sales Amount] - [Measures].[PromedioVentasPorPais], 
FORMAT_STRING = "Currency", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Internet Sales'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[PorcentajeVsPromedioPais]
 AS IIF(
    [Measures].[PromedioVentasPorPais] = 0, NULL,
    ([Measures].[Sales Amount] - [Measures].[PromedioVentasPorPais]) 
    / [Measures].[PromedioVentasPorPais]
  ), 
FORMAT_STRING = "Percent", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Internet Sales'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[IndicadorBajoRendimiento]
 AS IIF(
    [Measures].[Sales Amount] &lt; [Measures].[PromedioVentasPorPais],
    1,0
  ), 
FORMAT_STRING = "Standard", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Internet Sales'  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>